# 应用配置
APP_NAME=智慧社区服务
APP_ENV=development
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/community_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# 微信小程序配置
WECHAT_APPID=
WECHAT_SECRET=
